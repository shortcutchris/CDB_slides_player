{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CDBrain Slide Player",
  "version": "0.1.1",
  "identifier": "de.cdbrain.slideplayer",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "CDBrain Slide Player",
        "width": 1320,
        "height": 860,
        "minWidth": 980,
        "minHeight": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgyRUY4RTFCNDNDQ0ZFMkUKUldRdS9zeERHNDd2Z3VwWmZOVTVCYThUVmRXcXU0ZlZTYjNiajRveHFXNVdtMGRtMGJtck9JS3gK",
      "endpoints": [
        "https://github.com/shortcutchris/CDB_slides_player/releases/latest/download/latest.json"
      ]
    }
  }
}
