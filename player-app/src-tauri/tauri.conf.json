{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CDBrain Slide Player",
  "version": "0.1.0",
  "identifier": "de.cdbrain.slideplayer",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "CDBrain Slide Player",
        "width": 1320,
        "height": 860,
        "minWidth": 980,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
